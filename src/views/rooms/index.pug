extends ../layouts/main

block content
  // HEADER
  div(class="max-w-7xl mx-auto mb-10")
    div(class="flex flex-col lg:flex-row lg:items-end justify-between gap-6")
      div
        h2(class="text-xs font-bold text-blue-500 dark:text-rose-500 mb-1 tracking-widest uppercase") Gestión Hospitalaria
        h1(class="text-4xl font-bold tracking-tight text-slate-900 dark:text-white")
          | Mapa de <span class="text-blue-600 dark:text-rose-500">Camas</span>
      
      div(class="w-full max-w-md")
        input(type="text" id="searchInput" placeholder="Buscar habitación, cama o paciente..." class="w-full pl-4 pr-4 py-3 bg-white dark:bg-slate-800 border border-slate-300 dark:border-slate-600 rounded-2xl shadow-sm focus:ring-4 focus:ring-blue-100 dark:focus:ring-rose-900/30 focus:border-blue-500 dark:focus:border-rose-500 outline-none transition-all text-slate-900 dark:text-white")

  // ALERTA
  if error
    div(class="max-w-7xl mx-auto mb-8 animate-bounce")
      div(class="bg-red-50 dark:bg-red-900/30 border-2 border-red-200 dark:border-red-800 rounded-2xl p-4 flex items-center gap-4 shadow-lg shadow-red-500/10")
        div(class="text-2xl") ⚠️
        div
          h3(class="font-bold text-red-800 dark:text-red-200") Acción No Permitida
          p(class="text-sm text-red-700 dark:text-red-300") #{error}

  // --- NUEVA ESTRUCTURA POR ALAS ---
  div(class="max-w-7xl mx-auto space-y-12")
    if alas && alas.length > 0
      each ala in alas
        
        // CABECERA DEL ALA
        div(class="border-b-2 border-slate-200 dark:border-slate-700 pb-2 mb-6")
          h2(class="text-2xl font-black text-slate-800 dark:text-slate-100 uppercase tracking-wide") 🏥 Ala: #{ala.nombre}
          if ala.descripcion
            p(class="text-slate-500 text-sm") #{ala.descripcion}

        // GRID DE HABITACIONES DEL ALA
        div(class="grid grid-cols-1 lg:grid-cols-2 xl:grid-cols-3 gap-8")
          each habitacion in ala.Habitacions || []
            
            // TARJETA PRINCIPAL DE HABITACIÓN
            div(class="habitacion-card group bg-white dark:bg-slate-800 border border-slate-300 dark:border-slate-600 rounded-[2rem] p-8 shadow-sm hover:shadow-lg transition-all flex flex-col")
              
              div(class="flex justify-between items-center mb-6")
                div
                  h2(class="text-2xl font-bold text-slate-900 dark:text-white") Habitación #{habitacion.numero}
                  p(class="text-sm text-slate-500 dark:text-slate-400 font-medium uppercase tracking-wide") #{habitacion.tipo}
                div(class="w-10 h-10 rounded-xl bg-slate-100 dark:bg-slate-700 flex items-center justify-center text-xl border border-slate-200 dark:border-slate-600") 🚪

              // LISTA DE CAMAS
              div(class="space-y-4")
                each cama in habitacion.Camas || []
                  - let estadoClass = ''
                  - let icono = ''
                  - let nombrePaciente = null
                  - let idInternacion = null
                  
                  // Evaluamos el paciente si está ocupada
                  if cama.estado === 'Ocupada' && cama.Internacions && cama.Internacions.length > 0
                    // Tomamos la internación activa (la primera del array ordenado)
                    - const internacionActiva = cama.Internacions[0]
                    - idInternacion = internacionActiva.id
                    if internacionActiva.Paciente
                      if internacionActiva.Paciente.es_nn
                        - nombrePaciente = 'Emergencia (NN)'
                      else
                        - nombrePaciente = internacionActiva.Paciente.nombre + ' ' + internacionActiva.Paciente.apellido
                  
                  // Estilos por estado
                  if cama.estado === 'Disponible'
                    - estadoClass = 'border-green-300 bg-green-50 text-green-800 dark:bg-green-900/30 dark:border-green-700 dark:text-green-300'
                    - icono = '✨'
                  else if cama.estado === 'Limpieza'
                    - estadoClass = 'border-yellow-300 bg-yellow-50 text-yellow-800 dark:bg-yellow-900/30 dark:border-yellow-700 dark:text-yellow-300'
                    - icono = '🧹'
                  else
                    - estadoClass = 'border-red-300 bg-red-50 text-red-900 dark:bg-red-900/20 dark:border-red-700 dark:text-red-200'
                    - icono = '🛏️'

                  // CAMA ITEM
                  div(class=`cama-item relative p-4 rounded-xl border-2 transition-all flex flex-col gap-2 ${estadoClass}`)
                    div(class="flex justify-between items-center")
                      span(class="font-bold text-xs uppercase tracking-wider opacity-80 dark:text-slate-300") Cama #{cama.numero_cama}
                      span(class="text-lg") #{icono}

                    if cama.estado === 'Ocupada' && nombrePaciente
                      div
                        p(class="text-[10px] text-slate-500 dark:text-slate-400 uppercase font-bold") Paciente Internado
                        p(class="nombre-paciente font-bold text-slate-900 dark:text-white text-lg leading-tight") #{nombrePaciente}
                        
                        div(class="flex gap-2 mt-3")
                          // Botones directos sin javascript complejo
                          a(href=`/enfermeria/evaluar/${idInternacion}` class="flex-1 text-center py-1.5 px-2 rounded-lg bg-teal-100 text-teal-800 border border-teal-200 dark:bg-teal-900/60 dark:text-teal-200 dark:border-teal-700 text-xs font-bold hover:bg-teal-200 transition-colors") Signos
                          a(href=`/medico/evolucionar/${idInternacion}` class="flex-1 text-center py-1.5 px-2 rounded-lg bg-blue-100 text-blue-800 border border-blue-200 dark:bg-blue-900/60 dark:text-blue-200 dark:border-blue-700 text-xs font-bold hover:bg-blue-200 transition-colors") Evolución
                          a(href=`/clinica/historial/${cama.Internacions[0].Paciente.id}` class="flex-1 text-center py-1.5 px-2 rounded-lg bg-indigo-100 text-indigo-800 border border-indigo-200 text-xs font-bold hover:bg-indigo-200 transition-colors") Historia
                          a(href=`/internacion/${idInternacion}/alta` class="h-full px-3 rounded-lg bg-red-100 text-red-700 border border-red-200 dark:bg-red-900/60 dark:text-red-200 dark:border-red-700 text-xs font-bold hover:bg-red-200 transition-colors flex items-center justify-center") Alta

                    else if cama.estado === 'Limpieza'
                      div(class="flex justify-between items-end mt-2")
                        span(class="text-sm font-bold dark:text-yellow-200") Requiere Limpieza
                        form(action=`/habitaciones/limpiar/${cama.id}` method="POST")
                          button(type="submit" class="bg-yellow-400 text-yellow-900 px-3 py-1 rounded-lg text-xs font-bold hover:bg-yellow-500 shadow-sm") Habilitar

                    else
                      div(class="flex justify-between items-end mt-2")
                        span(class="text-sm font-bold dark:text-green-200") Lista para uso
                        a(href=`/internacion/nuevo?cama_id=${cama.id}` class="bg-green-600 text-white px-4 py-1.5 rounded-lg text-xs font-bold hover:bg-green-700") + Internar

    else
      div(class="text-center py-20")
        p(class="text-xl text-slate-500 font-bold") No hay alas ni habitaciones configuradas en el sistema.

  script.
    // Buscador simple
    const searchInput = document.getElementById('searchInput');
    const habitaciones = document.querySelectorAll('.habitacion-card');
    searchInput.addEventListener('keyup', (e) => {
      const term = e.target.value.toLowerCase();
      habitaciones.forEach(card => {
        const content = card.textContent.toLowerCase();
        if (content.includes(term)) {
          card.style.display = 'flex';
        } else { 
          card.style.display = 'none'; 
        }
      });
    });