extends ../layouts/main

block content
  div(class="max-w-3xl mx-auto mt-10")
    //- Cabecera
    div(class="mb-8")
      h2(class="text-sm font-bold text-blue-600 uppercase tracking-widest mb-1") Gestión de Admisión
      h1(class="text-3xl font-black text-slate-900") Nueva Internación
      p(class="text-slate-500 mt-2") Asignando paciente a la cama seleccionada.

    //- Tarjeta informativa de la cama
    div(class="bg-blue-50 border border-blue-200 rounded-2xl p-6 mb-8 flex items-center gap-4")
      div(class="text-4xl") 🛏️
      div
        p(class="text-sm text-blue-600 font-bold uppercase tracking-wide") Cama Seleccionada
        p(class="text-xl font-bold text-slate-900") Cama Número #{cama.numero_cama}
if generoRestringido
      div(class="bg-yellow-50 border-l-4 border-yellow-500 p-4 mb-8 rounded-r-2xl shadow-sm")
        div(class="flex items-center gap-3")
          span(class="text-2xl") ⚠️
          div
            p(class="text-sm text-yellow-800 font-bold uppercase tracking-wide") Habitación Segmentada por Sexo
            p(class="text-xs text-yellow-700 mt-1") Esta habitación compartida ya está ocupada por un paciente de sexo 
              strong #{generoRestringido === 'M' ? 'Masculino' : 'Femenino'}
              | . La lista de pacientes se ha filtrado automáticamente para mostrar solo opciones compatibles.
    //- Formulario
    form(action="/internacion/nueva" method="POST" class="bg-white border border-slate-200 shadow-sm rounded-2xl p-8 space-y-6")
      //- Campo oculto para mandar el ID de la cama al backend
      input(type="hidden" name="cama_id" value=cama.id)

      div
        label(class="block text-sm font-bold text-slate-700 mb-2") Seleccionar Paciente
        select(name="paciente_id" class="w-full border border-slate-300 rounded-xl px-4 py-3 bg-slate-50 focus:ring-2 focus:ring-blue-500 outline-none" required)
          option(value="" disabled selected) -- Elija un paciente del padrón --
          each paciente in pacientes
            option(value=paciente.id) #{paciente.apellido}, #{paciente.nombre} - DNI: #{paciente.dni || 'NN'}

      div(class="grid grid-cols-2 gap-6")
        div
          label(class="block text-sm font-bold text-slate-700 mb-2") Origen del Ingreso
          select(name="origen" class="w-full border border-slate-300 rounded-xl px-4 py-3 bg-slate-50 focus:ring-2 focus:ring-blue-500 outline-none" required)
            option(value="Guardia") Guardia / Urgencias
            option(value="Consultorio Externo") Consultorio Externo
            option(value="Derivacion") Derivación de otro centro
        
        div
          label(class="block text-sm font-bold text-slate-700 mb-2") Prioridad (Triage)
          select(name="prioridad_triage" class="w-full border border-slate-300 rounded-xl px-4 py-3 bg-slate-50 focus:ring-2 focus:ring-blue-500 outline-none" required)
            option(value="Verde") 🟢 Verde (Normal)
            option(value="Amarillo") 🟡 Amarillo (Urgencia)
            option(value="Rojo") 🔴 Rojo (Emergencia)

      div
        label(class="block text-sm font-bold text-slate-700 mb-2") Motivo de Internación / Diagnóstico Presuntivo
        textarea(name="motivo" rows="4" class="w-full border border-slate-300 rounded-xl px-4 py-3 bg-slate-50 focus:ring-2 focus:ring-blue-500 outline-none" placeholder="Describa brevemente la razón del ingreso..." required)

      //- Botones
      div(class="flex gap-4 pt-4 border-t border-slate-100")
        a(href="/clinica/dashboard" class="w-1/3 text-center bg-white border-2 border-slate-200 text-slate-700 font-bold py-3 rounded-xl hover:bg-slate-50 transition") Cancelar
        button(type="submit" class="w-2/3 bg-blue-600 text-white font-bold py-3 rounded-xl hover:bg-blue-700 shadow-md transition") Confirmar Internación