extends ../layouts/main

block content
  div(class="max-w-3xl mx-auto mt-10")
    //- Cabecera
    div(class="mb-8 flex justify-between items-center")
      div
        h2(class="text-sm font-bold text-blue-600 uppercase tracking-widest mb-1") Gestión de Internación
        h1(class="text-3xl font-black text-slate-900 dark:text-white") Traslado de Cama

      a(href="/habitaciones" class="text-slate-500 hover:text-blue-600 dark:text-slate-400 dark:hover:text-white font-bold text-sm transition-colors") &larr; Volver al Mapa

    if error
      div(class="bg-red-50 dark:bg-red-900/30 text-red-800 dark:text-red-200 p-4 mb-6 rounded-xl border border-red-200 dark:border-red-800 font-bold")
        p 🛑 Error: #{error}

    //- Info del paciente y cama actual
    div(class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8")
      // Paciente
      div(class="bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-2xl p-6 shadow-sm")
        p(class="text-xs text-slate-400 font-bold uppercase tracking-wider mb-1") Paciente Internado
        h3(class="text-xl font-bold text-slate-900 dark:text-white") #{internacion.Paciente.nombre} #{internacion.Paciente.apellido}
        p(class="text-xs text-slate-500 mt-1") DNI: #{internacion.Paciente.dni || 'NN'} • Sexo: #{internacion.Paciente.sexo}

      // Cama Actual
      div(class="bg-blue-50 dark:bg-blue-900/20 border border-blue-100 dark:border-blue-800 rounded-2xl p-6 shadow-sm flex items-center gap-4")
        div(class="text-3xl") 🛏️
        div
          p(class="text-xs text-blue-600 dark:text-blue-400 font-bold uppercase tracking-wider mb-1") Cama Actual
          h3(class="text-lg font-bold text-slate-900 dark:text-white") Cama #{internacion.Cama ? internacion.Cama.numero_cama : 'Ninguna'}
          p(class="text-xs text-slate-500 mt-0.5") Habitación #{internacion.Cama && internacion.Cama.Habitacion ? internacion.Cama.Habitacion.numero : 'Sin Habitación'} (#{internacion.Cama && internacion.Cama.Habitacion ? internacion.Cama.Habitacion.tipo : ''})

    //- Formulario de Transferencia
    form(action=`/internacion/${internacion.id}/transferir` method="POST" class="bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 shadow-sm rounded-2xl p-8 space-y-6")
      
      div
        label(class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2") Seleccionar Nueva Cama Destino
        if camas && camas.length > 0
          select(name="nueva_cama_id" class="w-full border border-slate-300 dark:border-slate-600 dark:bg-slate-900 dark:text-white rounded-xl px-4 py-3 bg-slate-50 focus:ring-2 focus:ring-blue-500 outline-none" required)
            option(value="" disabled selected) -- Seleccione una cama libre compatible --
            each cama in camas
              option(value=cama.id) Ala: #{cama.Habitacion.Ala ? cama.Habitacion.Ala.nombre : 'General'} - Hab. #{cama.Habitacion.numero} - Cama #{cama.numero_cama} (#{cama.Habitacion.tipo})
        else
          div(class="bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800 text-amber-800 dark:text-amber-200 p-4 rounded-xl text-sm")
            | ⚠️ No hay camas compatibles disponibles en este momento. Habilite camas en limpieza o libere camas en otras habitaciones.

      div
        label(class="block text-sm font-bold text-slate-700 dark:text-slate-300 mb-2") Motivo del Traslado
        textarea(name="motivo_transferencia" rows="4" class="w-full border border-slate-300 dark:border-slate-600 dark:bg-slate-900 dark:text-white rounded-xl px-4 py-3 bg-slate-50 focus:ring-2 focus:ring-blue-500 outline-none" placeholder="Describa la razón médica o técnica del cambio..." required)

      //- Botones
      div(class="flex gap-4 pt-4 border-t border-slate-100 dark:border-slate-700")
        a(href="/habitaciones" class="w-1/3 text-center bg-white dark:bg-slate-700 border border-slate-200 dark:border-slate-600 text-slate-700 dark:text-slate-300 font-bold py-3 rounded-xl hover:bg-slate-50 dark:hover:bg-slate-600 transition") Cancelar
        if camas && camas.length > 0
          button(type="submit" class="w-2/3 bg-blue-600 text-white font-bold py-3 rounded-xl hover:bg-blue-700 shadow-md transition") Confirmar Traslado
