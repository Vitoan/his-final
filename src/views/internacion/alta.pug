extends ../layouts/main

block content
  div(class="max-w-3xl mx-auto mt-10")
    div(class="mb-8")
      h2(class="text-sm font-bold text-red-600 uppercase tracking-widest mb-1") Cierre de Episodio
      h1(class="text-3xl font-black text-slate-900") Alta Médica
      p(class="text-slate-500 mt-2") Registre la epicrisis y el destino del paciente.

    //- Tarjeta del paciente
    div(class="bg-slate-50 border border-slate-200 rounded-2xl p-6 mb-8")
      p(class="text-xs text-slate-500 font-bold uppercase tracking-wide mb-1") Paciente
      p(class="text-xl font-bold text-slate-900 mb-2") #{internacion.Paciente.nombre} #{internacion.Paciente.apellido}
      div(class="text-sm text-slate-600 flex gap-4")
        span 📅 Ingreso: #{internacion.fecha_ingreso.toLocaleDateString()}
        span 🏥 Motivo: #{internacion.motivo}

    //- Formulario de Egreso
    form(action=`/internacion/${internacion.id}/alta` method="POST" class="bg-white border border-slate-200 shadow-sm rounded-2xl p-8 space-y-6")
      
      div
        label(class="block text-sm font-bold text-slate-700 mb-2") Tipo de Egreso
        select(name="estado_alta" class="w-full border border-slate-300 rounded-xl px-4 py-3 bg-slate-50 focus:ring-2 focus:ring-red-500 outline-none" required)
          option(value="Alta_Medica") ✅ Alta Médica (Mejoría)
          option(value="Traslado") 🚑 Traslado a otro centro
          option(value="Defuncion") ✝️ Defunción
      
      div
        label(class="block text-sm font-bold text-slate-700 mb-2") Resumen / Epicrisis
        textarea(name="resumen_epicrisis" rows="6" class="w-full border border-slate-300 rounded-xl px-4 py-3 bg-slate-50 focus:ring-2 focus:ring-red-500 outline-none" placeholder="Escriba el resumen final del paso del paciente por el hospital..." required)

      div(class="flex gap-4 pt-4 border-t border-slate-100")
        a(href="/clinica/dashboard" class="w-1/3 text-center bg-white border-2 border-slate-200 text-slate-700 font-bold py-3 rounded-xl hover:bg-slate-50 transition") Cancelar
        button(type="submit" class="w-2/3 bg-red-600 text-white font-bold py-3 rounded-xl hover:bg-red-700 shadow-md transition") Procesar Alta y Liberar Cama