extends ../layouts/main

block content
  div(class="max-w-3xl mx-auto mt-10 mb-10")
    div(class="mb-8 flex justify-between items-center")
      div
        h2(class="text-xs font-bold text-fuchsia-500 uppercase tracking-widest mb-1") Diagnóstico
        h1(class="text-3xl font-black text-slate-900") Solicitar Estudio
      a(href="/estudios" class="bg-slate-200 text-slate-700 font-bold py-2 px-4 rounded-xl hover:bg-slate-300 transition") Volver

    form(action="/estudios/nuevo" method="POST" class="bg-white border border-slate-200 shadow-sm rounded-3xl p-8 space-y-6")
      
      div(class="grid grid-cols-1 md:grid-cols-2 gap-6")
        div
          label(class="block text-sm font-bold text-slate-700 mb-2") Paciente
          select(name="paciente_id" class="w-full border border-slate-300 rounded-xl px-4 py-3 bg-slate-50 focus:ring-2 focus:ring-fuchsia-500 outline-none" required)
            option(value="" disabled selected) -- Seleccionar Paciente --
            each paciente in pacientes
              option(value=paciente.id) #{paciente.apellido}, #{paciente.nombre} (DNI: #{paciente.dni || 'NN'})
        
        div
          label(class="block text-sm font-bold text-slate-700 mb-2") Médico Solicitante
          select(name="medico_id" class="w-full border border-slate-300 rounded-xl px-4 py-3 bg-slate-50 focus:ring-2 focus:ring-fuchsia-500 outline-none" required)
            option(value="" disabled selected) -- Seleccionar Médico --
            if medicos && medicos.length > 0
              each medico in medicos
                option(value=medico.id) Dr/a. #{medico.apellido}, #{medico.nombre}

      div
        label(class="block text-sm font-bold text-slate-700 mb-2") Categoría del Estudio
        select(name="tipo_estudio" class="w-full border border-slate-300 rounded-xl px-4 py-3 bg-slate-50 focus:ring-2 focus:ring-fuchsia-500 outline-none" required)
          option(value="Laboratorio") Análisis de Laboratorio (Sangre, Orina, etc.)
          option(value="Radiología") Radiología (Rayos X)
          option(value="Ecografía") Ecografía / Ultrasonido
          option(value="Tomografía") Tomografía Computada (TAC)
          option(value="Resonancia") Resonancia Magnética (RMN)
          option(value="Otros") Otros Estudios

      div
        label(class="block text-sm font-bold text-slate-700 mb-2") Descripción / Orden Médica
        textarea(name="descripcion" rows="3" placeholder="Ej: Hemograma completo, Glucemia, Uremia... o Placa de Tórax frente." class="w-full border border-slate-300 rounded-xl px-4 py-3 bg-slate-50 focus:ring-2 focus:ring-fuchsia-500 outline-none" required)

      div(class="pt-6 border-t border-slate-100")
        button(type="submit" class="w-full bg-fuchsia-600 text-white font-bold py-4 rounded-xl hover:bg-fuchsia-700 shadow-md transition text-lg") Generar Orden de Estudio