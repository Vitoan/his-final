extends ../layouts/main

block content
  div(class="max-w-3xl mx-auto mt-10 mb-10")
    div(class="mb-8 flex justify-between items-center")
      div
        h2(class="text-xs font-bold text-emerald-600 uppercase tracking-widest mb-1") Laboratorio / Imágenes
        h1(class="text-3xl font-black text-slate-900") Cargar Informe Médico
      a(href="/estudios" class="bg-slate-200 text-slate-700 font-bold py-2 px-4 rounded-xl hover:bg-slate-300 transition") Cancelar

    //- Ficha de Resumen del Estudio (Solo lectura)
    div(class="bg-slate-50 border border-slate-200 rounded-2xl p-6 mb-8")
      h3(class="font-bold text-slate-800 text-lg mb-4 border-b border-slate-200 pb-2") Datos de la Orden
      div(class="grid grid-cols-2 gap-4 text-sm")
        div
          span(class="text-slate-500 block") Paciente:
          span(class="font-bold text-slate-900") #{estudio.Paciente.apellido}, #{estudio.Paciente.nombre}
        div
          span(class="text-slate-500 block") Médico Solicitante:
          span(class="font-bold text-slate-900") Dr/a. #{estudio.Medico.apellido}
        div
          span(class="text-slate-500 block") Categoría:
          span(class="font-bold text-fuchsia-700 uppercase") #{estudio.tipo_estudio}
        div
          span(class="text-slate-500 block") Fecha de Solicitud:
          span(class="font-bold text-slate-900") #{new Date(estudio.fecha_solicitud).toLocaleDateString()}
      div(class="mt-4 pt-4 border-t border-slate-200")
        span(class="text-slate-500 block mb-1") Detalle solicitado:
        p(class="font-medium text-slate-800 italic") "#{estudio.descripcion}"

    //- Formulario de Carga
    form(action=`/estudios/${estudio.id}/resultado` method="POST" class="bg-white border border-slate-200 shadow-sm rounded-3xl p-8")
      div
        label(class="block text-sm font-bold text-slate-700 mb-2") Informe de Resultados
        textarea(name="resultado" rows="8" placeholder="Escriba los resultados del laboratorio o el informe del diagnóstico por imágenes aquí..." class="w-full border border-slate-300 rounded-xl px-4 py-3 bg-slate-50 focus:ring-2 focus:ring-emerald-500 outline-none" required)
        p(class="text-xs text-slate-500 mt-2") Al guardar, el estado del estudio cambiará automáticamente a "Realizado".

      div(class="pt-8")
        button(type="submit" class="w-full bg-emerald-600 text-white font-bold py-4 rounded-xl hover:bg-emerald-700 shadow-md transition text-lg") Finalizar y Guardar Resultado