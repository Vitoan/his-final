extends ../layouts/main

block content
  div(class="max-w-4xl mx-auto mt-10")
    div(class="mb-8 flex justify-between items-center")
      div
        h2(class="text-sm font-bold text-indigo-600 uppercase tracking-widest mb-1") Episodio Clínico
        h1(class="text-3xl font-black text-slate-900") Historial de Internación
      a(href=`/clinica/historial/${internacion.Paciente.id}` class="bg-slate-200 text-slate-700 font-bold py-2 px-4 rounded-xl hover:bg-slate-300 transition") Volver al Historial

    //- Tarjeta Cabecera
    div(class="bg-white border-2 border-indigo-100 rounded-2xl p-6 mb-8 flex items-center justify-between shadow-sm")
      div
        p(class="text-sm text-slate-500 font-bold uppercase") Paciente
        p(class="text-2xl font-bold text-slate-900") #{internacion.Paciente.nombre} #{internacion.Paciente.apellido}
      div(class="text-right")
        p(class="text-sm text-slate-500 font-bold uppercase") Ingreso
        p(class="text-lg font-bold text-indigo-700") #{new Date(internacion.fecha_ingreso).toLocaleDateString()}
        p(class="text-xs text-slate-500 mt-1") Cama #{internacion.Cama.numero_cama}

    //- Motivo Original
    div(class="bg-indigo-50 dark:bg-indigo-950/20 border border-indigo-200 dark:border-indigo-800 rounded-xl p-5 mb-8")
      h3(class="text-xs font-bold text-indigo-800 dark:text-indigo-300 uppercase mb-2") Motivo de Ingreso (Triage: #{internacion.prioridad_triage})
      p(class="text-slate-800 dark:text-slate-300 italic") "#{internacion.motivo}"

    //- Resumen de Alta (Si la internación ya finalizó)
    if internacion.estado !== 'Activa' && internacion.estado !== 'Cancelada'
      div(class="bg-rose-50 dark:bg-rose-900/20 border-2 border-rose-200 dark:border-rose-800 rounded-2xl p-6 mb-8 shadow-sm relative overflow-hidden")
        div(class="absolute top-0 right-0 w-24 h-24 bg-rose-100 dark:bg-rose-950/40 rounded-full blur-2xl")
        
        h3(class="text-lg font-bold text-rose-800 dark:text-rose-200 mb-4 flex items-center gap-2") 
          span 📋
          | Informe de Egreso Médico (#{internacion.estado === 'Alta_Medica' ? 'Alta Médica' : (internacion.estado === 'Traslado' ? 'Traslado' : 'Defunción')})
        
        div(class="space-y-4 text-slate-800 dark:text-slate-200")
          div
            span(class="text-xs font-bold text-rose-600 dark:text-rose-400 uppercase tracking-wider block") Resumen Clínico / Epicrisis
            p(class="text-sm mt-1 leading-relaxed") #{internacion.resumen_epicrisis || 'No especificada.'}
          
          if internacion.recetas
            div(class="pt-3 border-t border-rose-100 dark:border-rose-900/50")
              span(class="text-xs font-bold text-rose-600 dark:text-rose-400 uppercase tracking-wider block") Recetas y Tratamiento Farmacológico
              p(class="text-sm mt-1 leading-relaxed font-mono bg-white dark:bg-slate-900 p-3 rounded-lg border border-rose-100 dark:border-rose-900/50") #{internacion.recetas}

          if internacion.recomendaciones
            div(class="pt-3 border-t border-rose-100 dark:border-rose-900/50")
              span(class="text-xs font-bold text-rose-600 dark:text-rose-400 uppercase tracking-wider block") Recomendaciones al Paciente
              p(class="text-sm mt-1 leading-relaxed") #{internacion.recomendaciones}

          if internacion.seguimiento
            div(class="pt-3 border-t border-rose-100 dark:border-rose-900/50")
              span(class="text-xs font-bold text-rose-600 dark:text-rose-400 uppercase tracking-wider block") Plan de Seguimiento / Próximos Controles
              p(class="text-sm mt-1 leading-relaxed font-bold") #{internacion.seguimiento}

    //- LÍNEA DE TIEMPO (Evoluciones)
    h3(class="text-xl font-black text-slate-800 mb-6") Evolución Clínica del Episodio
    
    if timeline && timeline.length > 0
      div(class="space-y-6 relative before:absolute before:inset-0 before:ml-5 before:-translate-x-px md:before:mx-auto md:before:translate-x-0 before:h-full before:w-0.5 before:bg-gradient-to-b before:from-indigo-500 before:via-slate-300 before:to-transparent")
        
        each item in timeline
          - let pres = '-'
          - let pulso = '-'
          - let temp = '-'
          - let autorNombre = item.Autor ? item.Autor.nombre : 'Personal de Salud'
          
          if item.tipoItem === 'SignosVitales'
            - pres = item.presion_arterial || '-'
            - pulso = item.frecuencia_cardiaca || '-'
            - temp = item.temperatura || '-'
          else
            - let sv = {}
            - try { sv = typeof item.signos_vitales === 'string' ? JSON.parse(item.signos_vitales) : (item.signos_vitales || {}) } catch(e) {}
            - pres = sv.presion || '-'
            - pulso = sv.frecuencia_cardiaca || sv.pulso || '-'
            - temp = sv.temperatura || sv.temp || '-'

          div(class="relative flex items-center justify-between md:justify-normal md:odd:flex-row-reverse group is-active")
            // Icono Central
            div(class=`flex items-center justify-center w-10 h-10 rounded-full border-4 border-white dark:border-slate-900 shrink-0 md:order-1 md:group-odd:-translate-x-1/2 md:group-even:translate-x-1/2 shadow-md ${item.tipo === 'Medico' ? 'bg-blue-500' : 'bg-teal-500'}`)
              span(class="text-white text-xs") #{item.tipo === 'Medico' ? '👨‍⚕️' : '🩺'}
            
            // Tarjeta de Contenido
            div(class="w-[calc(100%-4rem)] md:w-[calc(50%-2.5rem)] bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-2xl p-5 shadow-sm")
              
              if item.tipo === 'Enfermeria' || item.tipoItem === 'SignosVitales'
                //- DISEÑO DE ENFERMERÍA (Signos Vitales)
                div(class="flex justify-between items-center mb-2")
                  span(class="text-[10px] font-bold text-slate-400 uppercase") #{new Date(item.createdAt).toLocaleDateString()}
                  span(class="text-[10px] font-bold text-slate-400 uppercase") #{new Date(item.createdAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})}
                
                //- Mini Grid de Valores
                div(class="grid grid-cols-3 gap-2 mb-3 bg-slate-50 dark:bg-slate-900/50 p-2 rounded-lg")
                  div(class="text-center")
                    span(class="block text-[9px] text-slate-400 uppercase") Pres.
                    span(class="font-mono font-bold text-slate-700 dark:text-white text-xs") #{pres}
                  
                  div(class="text-center border-l border-slate-200 dark:border-slate-700")
                    span(class="block text-[9px] text-slate-400 uppercase") Pulso
                    span(class="font-mono font-bold text-slate-700 dark:text-white text-xs") #{pulso}
                  
                  div(class="text-center border-l border-slate-200 dark:border-slate-700")
                    span(class="block text-[9px] text-slate-400 uppercase") Temp.
                    span(class="font-mono font-bold text-slate-700 dark:text-white text-xs") #{temp}°
                
                if item.nota
                  p(class="text-xs text-slate-600 dark:text-slate-300 italic line-clamp-2 mt-2") "#{item.nota}"
                p(class="text-[10px] text-slate-400 mt-2 text-right") Registrado por: #{autorNombre}

              else if item.tipo === 'Medico'
                //- DISEÑO MÉDICO
                div(class="flex justify-between items-center mb-2")
                  span(class="text-[10px] font-bold text-slate-400 uppercase") #{new Date(item.createdAt).toLocaleDateString()} • #{new Date(item.createdAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})}
                  span(class="text-[10px] font-bold text-slate-400 uppercase") Dr/a. #{autorNombre}
                
                - let sv = {}
                - try { sv = typeof item.signos_vitales === 'string' ? JSON.parse(item.signos_vitales) : (item.signos_vitales || {}) } catch(e) {}
                
                if sv.diagnostico
                  div(class="mb-2")
                    span(class="text-xs font-bold text-blue-600 dark:text-blue-400 block") Diagnóstico
                    p(class="text-sm text-slate-700 dark:text-slate-300 leading-snug") #{sv.diagnostico}
                
                if sv.tratamiento
                  div
                    span(class="text-xs font-bold text-teal-600 dark:text-teal-400 block") Tratamiento
                    p(class="text-sm text-slate-700 dark:text-slate-300 leading-snug") #{sv.tratamiento}
                
                //- Si es un registro viejo o texto libre
                if !sv.diagnostico && !sv.tratamiento && item.nota
                  p(class="text-sm text-slate-700 dark:text-slate-300 leading-snug mt-2") #{item.nota}
    else
      div(class="text-center py-10 opacity-50")
        div(class="text-4xl mb-2") 📅
        p(class="text-sm") No hay evoluciones registradas para este paciente.