extends ../layouts/main

block content
  div(class="max-w-4xl mx-auto mt-10")
    div(class="mb-8 flex justify-between items-center")
      div
        h2(class="text-sm font-bold text-indigo-600 uppercase tracking-widest mb-1") Episodio Clínico
        h1(class="text-3xl font-black text-slate-900") Historial de Internación
      a(href=`/clinica/historial/${internacion.Paciente.id}` class="bg-slate-200 text-slate-700 font-bold py-2 px-4 rounded-xl hover:bg-slate-300 transition") Volver al Historial

    //- Tarjeta Cabecera
    div(class="bg-white border-2 border-indigo-100 rounded-2xl p-6 mb-8 flex items-center justify-between shadow-sm")
      div
        p(class="text-sm text-slate-500 font-bold uppercase") Paciente
        p(class="text-2xl font-bold text-slate-900") #{internacion.Paciente.nombre} #{internacion.Paciente.apellido}
      div(class="text-right")
        p(class="text-sm text-slate-500 font-bold uppercase") Ingreso
        p(class="text-lg font-bold text-indigo-700") #{new Date(internacion.fecha_ingreso).toLocaleDateString()}
        p(class="text-xs text-slate-500 mt-1") Cama #{internacion.Cama.numero_cama}

    //- Motivo Original
    div(class="bg-indigo-50 border border-indigo-200 rounded-xl p-5 mb-8")
      h3(class="text-xs font-bold text-indigo-800 uppercase mb-2") Motivo de Ingreso (Triage: #{internacion.prioridad_triage})
      p(class="text-slate-800 italic") "#{internacion.motivo}"

    //- LÍNEA DE TIEMPO (Evoluciones)
    h3(class="text-xl font-black text-slate-800 mb-6") Evolución Clínica del Episodio
    
    if internacion.Evolucions && internacion.Evolucions.length > 0
      div(class="space-y-6 relative before:absolute before:inset-0 before:ml-5 before:-translate-x-px md:before:mx-auto md:before:translate-x-0 before:h-full before:w-0.5 before:bg-gradient-to-b before:from-indigo-500 before:via-slate-300 before:to-transparent")
        
        each evo in internacion.Evolucions
          //- Intentamos parsear el JSON de forma segura por si viene como texto
          - let sv = {}
          - try { sv = typeof evo.signos_vitales === 'string' ? JSON.parse(evo.signos_vitales) : (evo.signos_vitales || {}) } catch(e) {}

          div(class="relative flex items-center justify-between md:justify-normal md:odd:flex-row-reverse group is-active")
            // Icono Central
            div(class=`flex items-center justify-center w-10 h-10 rounded-full border-4 border-white dark:border-slate-900 shrink-0 md:order-1 md:group-odd:-translate-x-1/2 md:group-even:translate-x-1/2 shadow-md ${evo.tipo === 'Medico' ? 'bg-blue-500' : 'bg-teal-500'}`)
              span(class="text-white text-xs") #{evo.tipo === 'Medico' ? '👨‍⚕️' : '🩺'}
            
            // Tarjeta de Contenido
            div(class="w-[calc(100%-4rem)] md:w-[calc(50%-2.5rem)] bg-white dark:bg-slate-800 border border-slate-200 dark:border-slate-700 rounded-2xl p-5 shadow-sm")
              
              if evo.tipo === 'Enfermeria'
                //- DISEÑO DE ENFERMERÍA (Tu código adaptado)
                div(class="flex justify-between items-center mb-2")
                  span(class="text-[10px] font-bold text-slate-400 uppercase") #{new Date(evo.createdAt).toLocaleDateString()}
                  span(class="text-[10px] font-bold text-slate-400 uppercase") #{new Date(evo.createdAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})}
                
                //- Mini Grid de Valores
                div(class="grid grid-cols-3 gap-2 mb-3 bg-slate-50 dark:bg-slate-900/50 p-2 rounded-lg")
                  div(class="text-center")
                    span(class="block text-[9px] text-slate-400 uppercase") Pres.
                    span(class="font-mono font-bold text-slate-700 dark:text-white text-xs") #{sv.presion || '-'}
                  
                  div(class="text-center border-l border-slate-200 dark:border-slate-700")
                    span(class="block text-[9px] text-slate-400 uppercase") Pulso
                    span(class="font-mono font-bold text-slate-700 dark:text-white text-xs") #{sv.frecuencia_cardiaca || sv.pulso || '-'}
                  
                  div(class="text-center border-l border-slate-200 dark:border-slate-700")
                    span(class="block text-[9px] text-slate-400 uppercase") Temp.
                    span(class="font-mono font-bold text-slate-700 dark:text-white text-xs") #{sv.temperatura || sv.temp || '-'}°
                
                if evo.nota
                  p(class="text-xs text-slate-600 dark:text-slate-300 italic line-clamp-2 mt-2") "#{evo.nota}"

              else if evo.tipo === 'Medico'
                //- DISEÑO MÉDICO (Tu código adaptado)
                p(class="text-[10px] font-bold text-slate-400 uppercase mb-2") #{new Date(evo.createdAt).toLocaleDateString()} • #{new Date(evo.createdAt).toLocaleTimeString([], {hour: '2-digit', minute:'2-digit'})}
                
                if sv.diagnostico
                  div(class="mb-2")
                    span(class="text-xs font-bold text-blue-600 dark:text-blue-400 block") Diagnóstico
                    p(class="text-sm text-slate-700 dark:text-slate-300 leading-snug") #{sv.diagnostico}
                
                if sv.tratamiento
                  div
                    span(class="text-xs font-bold text-teal-600 dark:text-teal-400 block") Tratamiento
                    p(class="text-sm text-slate-700 dark:text-slate-300 leading-snug") #{sv.tratamiento}
                
                //- Si es un registro viejo que no tiene JSON, mostramos la nota completa
                if !sv.diagnostico && !sv.tratamiento && evo.nota
                  p(class="text-sm text-slate-700 dark:text-slate-300 leading-snug mt-2") #{evo.nota}