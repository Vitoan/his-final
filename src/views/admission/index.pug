extends ../layouts/main

block content
  div(class="max-w-7xl mx-auto mt-6 mb-10")
    div(class="flex justify-between items-end mb-8")
      div
        h2(class="text-xs font-bold text-indigo-500 uppercase tracking-widest mb-1") Administración
        h1(class="text-4xl font-black text-slate-900") Padrón de Pacientes
      a(href="/admision/nuevo" class="bg-indigo-600 hover:bg-indigo-700 text-white font-bold py-3 px-6 rounded-xl shadow-md transition-colors") + Registrar Nuevo

    div(class="bg-white border border-slate-200 rounded-3xl overflow-hidden shadow-sm")
      table(class="w-full text-left border-collapse")
        thead(class="bg-slate-50 border-b border-slate-200 text-slate-500 text-xs uppercase tracking-wider")
          tr
            th(class="p-5 font-bold") Paciente
            th(class="p-5 font-bold") DNI / Contacto
            th(class="p-5 font-bold") Estado
            th(class="p-5 font-bold text-center") Acciones
        tbody(class="divide-y divide-slate-100")
          if pacientes && pacientes.length > 0
            each pac in pacientes
              tr(class="hover:bg-slate-50 transition-colors")
                td(class="p-5")
                  div(class="flex items-center gap-3")
                    div(class=`w-10 h-10 rounded-full flex items-center justify-center font-bold text-white ${pac.es_nn ? 'bg-red-500' : 'bg-indigo-500'}`)
                      | #{pac.nombre.charAt(0)}
                    div
                      p(class=`font-bold text-lg leading-tight ${pac.es_nn ? 'text-red-600' : 'text-slate-900'}`) #{pac.apellido}, #{pac.nombre}
                      if pac.es_nn
                        span(class="text-xs font-bold text-red-500 animate-pulse") ⚠️ Requiere Identificación
                td(class="p-5")
                  p(class="text-sm font-bold text-slate-700") DNI: #{pac.dni || 'No registrado'}
                  p(class="text-xs text-slate-500") Tel: #{pac.telefono || 'N/A'}
                td(class="p-5")
                  if pac.Internacions && pac.Internacions.length > 0
                    span(class="bg-blue-100 text-blue-800 text-xs font-bold px-3 py-1 rounded-lg") Internado
                  else
                    span(class="bg-slate-100 text-slate-600 text-xs font-bold px-3 py-1 rounded-lg") Ambulatorio
                td(class="p-5 flex justify-center gap-2")
                  a(href=`/admision/editar/${pac.id}` class="bg-slate-100 text-slate-700 hover:bg-slate-200 px-4 py-2 rounded-lg text-sm font-bold transition-colors") Editar Ficha
          else
            tr
              td(colspan="4" class="p-10 text-center text-slate-500 font-bold") No hay pacientes registrados.