extends ../layouts/main

block content
  div(class="max-w-4xl mx-auto mt-10 mb-10")
    div(class="mb-8 flex justify-between items-center")
      div
        h2(class="text-xs font-bold text-indigo-500 uppercase tracking-widest mb-1") Ficha Médica
        h1(class="text-3xl font-black text-slate-900") #{title}
      a(href="/admision" class="bg-slate-200 text-slate-700 font-bold py-2 px-4 rounded-xl hover:bg-slate-300 transition") Cancelar

    if error
      div(class="bg-red-50 text-red-700 border border-red-200 p-4 rounded-xl mb-6 font-bold") #{error}

    //- Alerta si estamos identificando a un NN
    if isEditing && data && data.es_nn
      div(class="bg-rose-50 border-2 border-rose-200 rounded-2xl p-6 mb-8 flex items-center gap-4")
        div(class="text-4xl") 🚨
        div
          p(class="text-sm text-rose-700 font-bold uppercase tracking-wide") Proceso de Identificación
          p(class="text-slate-700 mt-1") Este paciente ingresó como Emergencia (NN). Por favor, complete su DNI y Nombre real para integrarlo al padrón.

    //- El formulario apunta dinámicamente según si creamos o editamos
    - const actionUrl = isEditing ? `/admision/editar/${data.id}` : '/admision/nuevo'

    form(action=actionUrl method="POST" class="bg-white border border-slate-200 shadow-sm rounded-3xl p-8 space-y-6")
      
      div(class="grid grid-cols-1 md:grid-cols-2 gap-6")
        div
          label(class="block text-sm font-bold text-slate-700 mb-2") Nombre(s)
          input(type="text" name="nombre" value=(data ? data.nombre : '') class="w-full border border-slate-300 rounded-xl px-4 py-3 bg-slate-50 focus:ring-2 focus:ring-indigo-500 outline-none" required)
        
        div
          label(class="block text-sm font-bold text-slate-700 mb-2") Apellido(s)
          input(type="text" name="apellido" value=(data ? data.apellido : '') class="w-full border border-slate-300 rounded-xl px-4 py-3 bg-slate-50 focus:ring-2 focus:ring-indigo-500 outline-none" required)

      div(class="grid grid-cols-1 md:grid-cols-3 gap-6")
        div
          label(class="block text-sm font-bold text-slate-700 mb-2") DNI
          input(type="number" name="dni" value=(data ? data.dni : '') placeholder="Sin puntos" class="w-full border border-slate-300 rounded-xl px-4 py-3 bg-slate-50 focus:ring-2 focus:ring-indigo-500 outline-none")
        
        div
          label(class="block text-sm font-bold text-slate-700 mb-2") Sexo Biológico
          select(name="sexo" class="w-full border border-slate-300 rounded-xl px-4 py-3 bg-slate-50 focus:ring-2 focus:ring-indigo-500 outline-none" required)
            - const selSexo = data ? data.sexo : ''
            option(value="Masculino" selected=(selSexo==='Masculino' || selSexo==='M')) Masculino
            option(value="Femenino" selected=(selSexo==='Femenino' || selSexo==='F')) Femenino
            option(value="X" selected=(selSexo==='X')) Sin Especificar (X)

        div
          label(class="block text-sm font-bold text-slate-700 mb-2") F. Nacimiento
          - let fechaNac = data && data.fecha_nacimiento ? (typeof data.fecha_nacimiento === 'string' ? data.fecha_nacimiento.split('T')[0] : data.fecha_nacimiento.toISOString().split('T')[0]) : ''
          input(type="date" name="fecha_nacimiento" value=fechaNac class="w-full border border-slate-300 rounded-xl px-4 py-3 bg-slate-50 focus:ring-2 focus:ring-indigo-500 outline-none")

      div(class="grid grid-cols-1 md:grid-cols-3 gap-6")
        div
          label(class="block text-sm font-bold text-slate-700 mb-2") Teléfono
          input(type="text" name="telefono" value=(data ? data.telefono : '') class="w-full border border-slate-300 rounded-xl px-4 py-3 bg-slate-50")
        div
          label(class="block text-sm font-bold text-slate-700 mb-2") Correo Electrónico
          input(type="email" name="email" value=(data ? data.email : '') class="w-full border border-slate-300 rounded-xl px-4 py-3 bg-slate-50")
        div
          label(class="block text-sm font-bold text-slate-700 mb-2") Obra Social
          input(type="text" name="obra_social" value=(data ? data.obra_social : '') class="w-full border border-slate-300 rounded-xl px-4 py-3 bg-slate-50")

      div
        label(class="block text-sm font-bold text-slate-700 mb-2") Dirección Postal
        input(type="text" name="direccion" value=(data ? data.direccion : '') class="w-full border border-slate-300 rounded-xl px-4 py-3 bg-slate-50")

      div(class="pt-6 border-t border-slate-100")
        button(type="submit" class="w-full bg-indigo-600 text-white font-bold py-4 rounded-xl hover:bg-indigo-700 shadow-md transition text-lg") #{isEditing ? 'Guardar Cambios' : 'Registrar Paciente'}